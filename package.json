{
  "name": "ship-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for ship, agent, and adapters",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npm run test -w @i-santos/ship && npm run test -w @i-santos/agent",
    "check": "npm run check -w @i-santos/ship && npm run check -w @i-santos/agent",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run check && changeset publish",
    "beta:enter": "changeset pre enter beta",
    "beta:exit": "changeset pre exit",
    "beta:version": "changeset version",
    "beta:publish": "changeset publish",
    "beta:promote": "ship promote-stable --dir ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7"
  }
}
