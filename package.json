{
  "name": "@i-santos/ship",
  "version": "1.0.0-beta.6",
  "description": "Reusable release orchestration engine for PR/release flows",
  "license": "MIT",
  "author": "Igor Santos",
  "homepage": "https://github.com/i-santos/ship#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i-santos/ship.git"
  },
  "bugs": {
    "url": "https://github.com/i-santos/ship/issues"
  },
  "keywords": [
    "release",
    "orchestration",
    "cli",
    "github",
    "workflow"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ship": "bin/ship.js"
  },
  "files": [
    "bin",
    "lib",
    "template",
    "README.md"
  ],
  "scripts": {
    "check": "npm run test",
    "test": "node --test tests/*.test.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run check && changeset publish",
    "beta:enter": "changeset pre enter beta",
    "beta:exit": "changeset pre exit",
    "beta:version": "changeset version",
    "beta:publish": "changeset publish",
    "beta:promote": "ship promote-stable --dir ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7"
  }
}
